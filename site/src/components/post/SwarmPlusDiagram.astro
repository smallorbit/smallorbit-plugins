<svg viewBox="0 0 640 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="/swarm-plus pipeline: each PR gets one reviewer pass; concerns trigger one fix-round, then PR is left for human merge. No re-review.">
  <defs>
    <marker id="arrow-plus" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0,0 L10,5 L0,10 z" fill="#a8a29c" />
    </marker>
    <marker id="arrow-plus-accent" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0,0 L10,5 L0,10 z" fill="#166534" />
    </marker>
  </defs>

  <text class="muted" x="320" y="22" text-anchor="middle" font-size="11" font-style="italic">per PR, in parallel</text>

  <rect class="node node--accent" x="30" y="120" width="120" height="60" rx="8" />
  <text x="90" y="148" text-anchor="middle" font-size="13" font-weight="500">agent</text>
  <text class="muted mono" x="90" y="166" text-anchor="middle" font-size="11">opens PR</text>

  <line class="edge" x1="150" y1="150" x2="195" y2="150" marker-end="url(#arrow-plus)" />

  <rect class="node" x="195" y="120" width="110" height="60" rx="6" />
  <text x="250" y="148" text-anchor="middle" font-size="13" font-weight="500">reviewer</text>
  <text class="muted" x="250" y="166" text-anchor="middle" font-size="11">verdict</text>

  <line class="edge" x1="305" y1="135" x2="370" y2="80" marker-end="url(#arrow-plus)" />
  <line class="edge edge--accent" x1="305" y1="165" x2="370" y2="220" marker-end="url(#arrow-plus-accent)" />

  <text class="muted" x="335" y="100" font-size="10" font-style="italic">approve</text>
  <text x="335" y="206" font-size="10" font-style="italic" fill="#166534">blockers /
concerns</text>

  <rect class="node" x="370" y="50" width="180" height="60" rx="6" />
  <text x="460" y="78" text-anchor="middle" font-size="13" font-weight="500">awaits human merge</text>
  <text class="muted mono" x="460" y="96" text-anchor="middle" font-size="11">terminate</text>

  <rect class="node node--accent" x="370" y="190" width="180" height="60" rx="8" />
  <text x="460" y="218" text-anchor="middle" font-size="13" font-weight="500">builder fix-round</text>
  <text class="muted mono" x="460" y="236" text-anchor="middle" font-size="11">single pass, no re-review</text>

  <path class="edge edge--dashed" d="M460,250 Q460,280 250,280 Q90,280 90,200 L90,182" marker-end="url(#arrow-plus)" />
  <text class="muted" x="280" y="275" text-anchor="middle" font-size="10" font-style="italic">push fix → PR updated</text>
</svg>
