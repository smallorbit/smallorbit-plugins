---
interface Props {
  kit?: string;
  cite?: string;
}

const { kit, cite } = Astro.props;
const accent = kit ? `var(--${kit}, var(--color-accent))` : 'var(--color-accent)';
---

<aside class="callout" style={`--callout-accent: ${accent};`}>
  <div class="callout__body">
    <slot />
    {cite && <footer class="callout__cite">&mdash; {cite}</footer>}
  </div>
</aside>

<style>
  .callout {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 4px solid var(--callout-accent);
    background: var(--bg-raised);
    border-radius: 0 var(--r-md) var(--r-md) 0;
    color: var(--text-strong);
  }

  .callout__body {
    font-family: var(--serif);
    font-size: 1.15rem;
    line-height: 1.55;
    font-weight: 400;
  }

  .callout__body :global(p) {
    margin: 0;
  }

  .callout__body :global(p + p) {
    margin-top: 0.75rem;
  }

  .callout__cite {
    margin-top: 0.75rem;
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: normal;
  }
</style>
