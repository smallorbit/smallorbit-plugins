---
import { getCollection } from 'astro:content';
import { stripExt } from '../../lib/slug';

const baseHref = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const posts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featured = sorted[0];

const slug = featured ? stripExt(featured.id) : null;
const href = slug ? `${baseHref}blog/${slug}/` : `${baseHref}blog/`;
const accentVar = featured?.data.kit
  ? `var(--${featured.data.kit}, var(--color-accent))`
  : 'var(--color-accent)';
---

{featured && (
  <section class="featured" aria-labelledby="featured-title" style={`--featured-accent: ${accentVar};`}>
    <div class="featured__container">
      <span class="featured__eyebrow">from the blog</span>
      <a class="featured__card" href={href}>
        <div class="featured__body">
          {featured.data.kit && <span class="featured__kit">{featured.data.kit}</span>}
          <h2 id="featured-title" class="featured__title">{featured.data.title}</h2>
          {featured.data.subtitle && <p class="featured__subtitle">{featured.data.subtitle}</p>}
          <p class="featured__meta">
            {featured.data.readTime && <span>{featured.data.readTime} min read</span>}
          </p>
        </div>
        <span class="featured__cta">
          Read it<span aria-hidden="true">↗</span>
        </span>
      </a>
      <p class="featured__more">
        <a href={`${baseHref}blog/`}>Browse all posts →</a>
      </p>
    </div>
  </section>
)}

<style>
  .featured {
    background: var(--bg-veil);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .featured__container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 4rem 1.25rem 3.25rem;
  }

  .featured__eyebrow {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 1.5rem;
  }

  .featured__card {
    display: flex;
    align-items: stretch;
    gap: 2rem;
    padding: 2rem 2.25rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-left: 4px solid var(--featured-accent);
    border-radius: var(--r-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .featured__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(26, 22, 18, 0.06);
  }

  .featured__body {
    flex: 1;
    min-width: 0;
  }

  .featured__kit {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--featured-accent);
    background: var(--bg-veil);
    padding: 0.15rem 0.55rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--featured-accent);
    border-radius: var(--r-xs);
    margin: 0 0 0.75rem;
  }

  .featured__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.4rem, 2.6vw, 1.85rem);
    line-height: 1.2;
    color: var(--text-strong);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .featured__subtitle {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.45;
  }

  .featured__meta {
    margin: 0;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .featured__cta {
    flex-shrink: 0;
    align-self: center;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    color: var(--featured-accent);
    font-size: 1rem;
  }

  .featured__more {
    margin: 1.25rem 0 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .featured__more a {
    color: var(--text);
  }

  .featured__more a:hover {
    color: var(--text-strong);
  }

  @media (max-width: 720px) {
    .featured__card {
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem 1.5rem;
    }
    .featured__cta {
      align-self: flex-start;
    }
  }
</style>
