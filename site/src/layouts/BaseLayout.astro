---
import TopNav from '../components/nav/TopNav.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  showTopNav?: boolean;
  active?: 'blog' | 'kits' | 'about';
}

const {
  title = 'smallorbit-plugins',
  description = 'Plan, execute, and ship — Claude Code plugin essays and kit deep-dives from smallorbit.',
  ogImage,
  ogType = 'website',
  showTopNav = true,
  active,
} = Astro.props;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://smallorbit.github.io';
const baseHref = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const canonicalUrl = new URL(Astro.url.pathname, `${siteOrigin}${baseHref}`).toString();
const resolvedOgImage = ogImage ?? `${siteOrigin}${baseHref}og/default.png`;
const githubRepoUrl = 'https://github.com/smallorbit/smallorbit-plugins';
const rssUrl = `${siteOrigin}${baseHref}rss.xml`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content="smallorbit-plugins" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title="smallorbit-plugins blog"
      href={rssUrl}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Mona+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --bg-page: #f8f6f1;
        --bg-raised: #ffffff;
        --bg-veil: #ede9e3;

        --text-strong: #1a1612;
        --text: #2e2a25;
        --text-muted: #737069;
        --text-dim: #8c8882;

        --color-bg: var(--bg-page);
        --color-text: var(--text);
        --color-accent: #4f46e5;

        --speckit: #7c3aed;
        --swarmkit: #166534;
        --polishkit: #b45309;
        --flowkit: #2563eb;
        --sessionkit: #a21caf;
        --vaultkit: #0f766e;
        --squadkit: #be123c;

        --link: #4f46e5;
        --link-hover: #3730a3;
        --link-visited: #475569;

        --border: #d4cfc8;
        --border-strong: #a8a29c;

        --r-xs: 4px;
        --r-sm: 6px;
        --r-md: 10px;
        --r-lg: 14px;
        --r-xl: 22px;

        --serif: 'Fraunces', 'Iowan Old Style', 'Times New Roman', serif;
        --sans: 'Mona Sans', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
        --mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace;

        --measure: 70ch;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        background: var(--bg-page);
        color: var(--text);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      img,
      svg {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a {
        color: var(--link);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
      }

      a:hover {
        color: var(--link-hover);
      }

      a:visited {
        color: var(--link-visited);
      }

      :focus-visible {
        outline: 2px solid var(--link);
        outline-offset: 2px;
        border-radius: var(--r-xs);
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
          scroll-behavior: auto !important;
        }
      }

      main {
        flex: 1 0 auto;
        width: 100%;
      }

      .site-footer {
        border-top: 1px solid var(--border);
        background: var(--bg-page);
        margin-top: 4rem;
      }

      .site-footer__inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 2rem 1.25rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 1.5rem;
        font-size: 0.9rem;
        color: var(--text-muted);
      }

      .site-footer__links {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
      }

      .site-footer__links a {
        color: var(--text);
        text-decoration: none;
      }

      .site-footer__links a:hover {
        color: var(--text-strong);
        text-decoration: underline;
      }
    </style>

    <slot name="head" />
  </head>
  <body>
    {showTopNav && <TopNav active={active} />}

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>&copy; {new Date().getFullYear()} smallorbit &middot; Plan, execute, and ship.</span>
        <div class="site-footer__links">
          <a href={githubRepoUrl} rel="noopener noreferrer">GitHub</a>
          <a href="https://claude.com/claude-code" rel="noopener noreferrer">Claude Code</a>
          <a href={rssUrl}>RSS</a>
        </div>
      </div>
    </footer>
  </body>
</html>
